<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:DropMe.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="DropMe.Views.Session"
             x:DataType="vm:MainViewModel">

    <Grid Background="#C4E0F2">

        <!-- Wrap everything in a Viewbox for automatic scaling -->
        <Viewbox Stretch="Uniform">
            <Grid Width="800" Height="450">

                <!-- Top-right End Session button -->
                <Button Content="End Session"
                        Click="BackButton_Click"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="12"
                        Width="105"
                        Height="35"
                        CornerRadius="8"
                        Background="Red"
                        Foreground="White"
                        FontWeight="Bold"/>

                <!-- TextBlocks -->
                <TextBlock Text="SessionID = "
                           HorizontalAlignment="Right"
                           VerticalAlignment="Top"
                           Margin="0,20,130,0"
                           FontSize="16"/>

                <TextBlock Text="Connected"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Top"
                           Margin="0,70,0,0"
                           FontSize="16"/>

                <!-- Centered White Border -->
                <Border Width="450"
                        Height="280"
                        Background="White"
                        CornerRadius="16"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Margin="0,100,0,0"/>

                <!-- Center Send Files Button -->
                <Button Content="Send Files"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Width="90"
                        Height="35"
                        Margin="0,0,0,80"
                        CornerRadius="8"
                        Background="#C4E0F2"
                        Foreground="Black"
                        FontWeight="Bold"/>

                <!-- Left Image -->
                <Image Source="avares://DropMe/Assets/profile_session.jpg"
                       Width="150"
                       Height="150"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Top"
                       Margin="200,150,0,0"
                       Stretch="Uniform"/>

                <!-- Right Image -->
                <Image Source="avares://DropMe/Assets/profile_session.jpg"
                       Width="150"
                       Height="150"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Top"
                       Margin="0,150,200,0"
                       Stretch="Uniform"/>

            </Grid>
        </Viewbox>

    </Grid>
</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:DropMe.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="800"
             d:DesignHeight="450"
             x:Class="DropMe.Views.Session"
             x:DataType="vm:MainViewModel">
  <Grid>
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
      <StackPanel MaxWidth="430" HorizontalAlignment="Center" Spacing="16" Margin="0,2,0,0">
        <Border Classes="AppCard">
          <StackPanel Spacing="8">
            <TextBlock Classes="PageTitle" Text="Active Drop Session"/>
            <Border Classes="SubCard">
              <StackPanel Spacing="6">
                <TextBlock Classes="SectionTitle" Text="Session ID"/>
                <TextBlock Text="{Binding SessionId}" TextWrapping="Wrap"/>
                <TextBlock Classes="BodyMuted"
                           Text="{Binding SessionStatus, StringFormat='Status: {0}'}"/>
              </StackPanel>
            </Border>
          </StackPanel>
        </Border>

        <Border Classes="AppCard">
          <StackPanel Spacing="12">
            <TextBlock Classes="SectionTitle" Text="Connected Peers"/>
            <Border Classes="SubCard" ClipToBounds="True">
              <Grid ColumnDefinitions="*,*" ColumnSpacing="14">
                <StackPanel Grid.Column="0" HorizontalAlignment="Center" Spacing="6">
                  <Image Source="avares://DropMe/Assets/profile_session.jpg"
                         Width="150"
                         Height="150"
                         Stretch="Uniform"/>
                  <TextBlock Classes="BodyMuted" Text="Your device"/>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Center" Spacing="6">
                  <Image Source="avares://DropMe/Assets/profile_session.jpg"
                         Width="150"
                         Height="150"
                         Stretch="Uniform"/>
                  <TextBlock Classes="BodyMuted" Text="Peer device"/>
                </StackPanel>
              </Grid>
            </Border>
          </StackPanel>
        </Border>

        <Border Classes="AppCard">
          <StackPanel Spacing="10">
            <TextBlock Classes="SectionTitle" Text="Actions"/>
            <Button Classes="FilledAction"
                    Height="44"
                    Content="Send Files"
                    Click="SendFiles_Click"/>
            <Button Classes="DangerAction"
                    Height="44"
                    Content="End Session"
                    Click="BackButton_Click"/>
          </StackPanel>
        </Border>

        <Border Classes="AppCard" IsVisible="{Binding HasSessionMessage}">
          <StackPanel Spacing="8">
            <TextBlock Classes="SectionTitle" Text="Transfer Updates"/>
            <Border Classes="SubCard">
              <TextBlock Text="{Binding SessionMessage}" TextWrapping="Wrap"/>
            </Border>
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>

    <Border IsVisible="{Binding HasPendingFileOffer}"
            Background="{DynamicResource WaterOverlayBrush}">
      <Border Classes="AppCard"
              MaxWidth="360"
              Margin="12"
              HorizontalAlignment="Center"
              VerticalAlignment="Center">
        <StackPanel Spacing="10">
          <TextBlock Classes="SectionTitle" Text="{Binding PendingFileOfferMessage}"/>
          <TextBlock Text="{Binding PendingFileOfferName, StringFormat='File: {0}'}"
                     TextWrapping="Wrap"/>
          <TextBlock Classes="BodyMuted"
                     Text="{Binding PendingFileOfferSizeText, StringFormat='Size: {0}'}"
                     TextWrapping="Wrap"/>

          <StackPanel Orientation="Horizontal"
                      Spacing="10"
                      HorizontalAlignment="Right"
                      Margin="0,6,0,0">
            <Button Classes="OutlinedAction"
                    Width="110"
                    Content="Reject"
                    Click="RejectIncomingFile_Click"/>
            <Button Classes="FilledAction"
                    Width="110"
                    Content="Accept"
                    Click="AcceptIncomingFile_Click"/>
          </StackPanel>
        </StackPanel>
      </Border>
    </Border>
  </Grid>
</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:DropMe.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="800"
             d:DesignHeight="450"
             x:Class="DropMe.Views.Session"
             x:DataType="vm:MainViewModel">
  <Grid Background="#C4E0F2">
    <StackPanel Orientation="Horizontal"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="14,14,0,0"
                Spacing="6"
                ZIndex="10">
        
        <Image IsVisible="{Binding IsTcpConnected}"
               Source="avares://DropMe/Assets/wifi_Icon.png"
               Width="24"
               Height="24"
               Stretch="Uniform"/>

        <Image IsVisible="{Binding IsBtConnected}"
               Source="avares://DropMe/Assets/Bluetooth_Icon.png"
               Width="30"
               Height="30"
               Stretch="Uniform"/>

    </StackPanel>
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
      <StackPanel MaxWidth="430" HorizontalAlignment="Center" Margin="0,40,0,40">
        <Border Padding="32"
                CornerRadius="32"
                Background="#60FFFFFF"
                BorderBrush="#80FFFFFF"
                BorderThickness="2">
          <StackPanel Spacing="32">
            
            <StackPanel Spacing="6">
              <TextBlock Classes="PageTitle"
                         Text="Active drop session"
                         Foreground="#04274A"
                         FontFamily="Georgia"
                         HorizontalAlignment="Center"/>

              <TextBlock Classes="BodyMuted"
                         Text="Secured. Fast."
                         FontFamily="Georgia"
                         Foreground="#6604274A"
                         HorizontalAlignment="Center"/>
            </StackPanel>
            
            <Border Padding="12"
                    CornerRadius="18"
                    Background="#E6EBF0"
                    BorderBrush="#D0D7DD"
                    BorderThickness="1">

              <StackPanel Spacing="6" HorizontalAlignment="Center">

                <TextBlock Text="{Binding SessionParticipantsText}"
                           FontSize="15"
                           FontFamily="Georgia"
                           FontWeight="SemiBold"
                           Foreground="#2A3A4A"
                           HorizontalAlignment="Center"/>

              </StackPanel>
            </Border>


        
          <StackPanel Spacing="16">
            
            <Border Padding="20"
                    CornerRadius="20"
                    Background="#30FFFFFF"
                    BorderBrush="#10FFFFFF"
                    BorderThickness="1"
                    ClipToBounds="True">
              
              <Grid ColumnDefinitions="*,*" ColumnSpacing="14"
                    HorizontalAlignment="Center">

                <StackPanel Grid.Column="0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="6">

                  <Image Source="avares://DropMe/Assets/Animation_DropMe.png"
                         Width="200"
                         Height="200"
                         Stretch="Uniform"/>

                </StackPanel>

              </Grid>

            </Border>
          </StackPanel>
            
            <StackPanel Spacing="22">
              <TextBlock Text="Actions"
                         HorizontalAlignment="Center"
                         FontSize="18"
                         FontWeight="SemiBold"
                         Foreground="#04274A"/>

              <Button Height="40"
                      CornerRadius="26"
                      Background="#E6E6E6"
                      Foreground="#04274A"
                      FontFamily="Georgia"
                      FontWeight="SemiBold"
                      Content="Choose download Folder"
                      Click="ChooseDownloadFolder_Click"/>

              <Button Height="40"
                      CornerRadius="26"
                      Background="#E6E6E6"
                      Foreground="#04274A"
                      FontFamily="Georgia"
                      FontWeight="SemiBold"
                      Content="Send Files"
                      Click="SendFiles_Click"/>

              <Button Height="40"
                      CornerRadius="26"
                      Background="#F2C8C8"
                      Foreground="#B00020"
                      FontFamily="Georgia"
                      FontWeight="SemiBold"
                      Content="End Session"
                      Click="BackButton_Click"/>
              
              <!-- ~1~ DEBUG @1@ -->
              <!-- <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center" Margin="0,10,0,0"> -->
              <!--   <Button Height="40" -->
              <!--           CornerRadius="26" -->
              <!--           Background="#FFCC00" -->
              <!--           Foreground="#333333" -->
              <!--           FontWeight="SemiBold" -->
              <!--           Content="[D] Toggle TCP" -->
              <!--           Click="DebugToggleTcp_Click"/> -->
              <!-- -->
              <!--   <Button Height="40" -->
              <!--           CornerRadius="26" -->
              <!--           Background="#FFCC00" -->
              <!--           Foreground="#333333" -->
              <!--           FontWeight="SemiBold" -->
              <!--           Content="[D] Toggle BT" -->
              <!--           Click="DebugToggleBt_Click"/> -->
              <!-- </StackPanel> -->
            </StackPanel>

            
            <StackPanel Spacing="12"
                        IsVisible="{Binding HasSessionMessage}">
              <TextBlock Classes="SectionTitle" Text="Transfer Updates"/>

              <Border Padding="14"
                      CornerRadius="16"
                      Background="#30FFFFFF"
                      BorderBrush="#10FFFFFF"
                      BorderThickness="1">
                <TextBlock Text="{Binding SessionMessage}" TextWrapping="Wrap"/>
              </Border>
            </StackPanel>

          </StackPanel>
        </Border>

      </StackPanel>
    </ScrollViewer>

    <Border IsVisible="{Binding HasPendingFileOffer}"
            Background="{DynamicResource WaterOverlayBrush}">
      <Border Classes="AppCard"
              MaxWidth="360"
              Margin="12"
              HorizontalAlignment="Center"
              VerticalAlignment="Center">
        <StackPanel Spacing="10">
          <TextBlock Classes="SectionTitle" Text="{Binding PendingFileOfferMessage}"/>
          <TextBlock Text="{Binding PendingFileOfferName, StringFormat='File: {0}'}"
                     TextWrapping="Wrap"/>
          <TextBlock Classes="BodyMuted"
                     Text="{Binding PendingFileOfferSizeText, StringFormat='Size: {0}'}"
                     TextWrapping="Wrap"/>

          <StackPanel Orientation="Horizontal"
                      Spacing="10"
                      HorizontalAlignment="Right"
                      Margin="0,6,0,0">
            <Button Classes="OutlinedAction"
                    Width="110"
                    Content="Reject"
                    Click="RejectIncomingFile_Click"/>
            <Button Classes="FilledAction"
                    Width="110"
                    Content="Accept"
                    Click="AcceptIncomingFile_Click"/>
          </StackPanel>
        </StackPanel>
      </Border>
    </Border>
  </Grid>
</UserControl>

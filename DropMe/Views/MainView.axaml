<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:DropMe.ViewModels"
    x:Class="DropMe.Views.MainView"
    x:DataType="vm:MainViewModel">

    <ScrollViewer>
        <StackPanel Spacing="10" Margin="12">

            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Generate QR" Click="GenerateQr_Click"/>
                <Button Content="Scan QR" Click="ScanQr_Click"/>
                <Button Content="Send File" IsEnabled="{Binding IsConnected}" Click="SendFile_Click"/>
            </StackPanel>

            <TextBlock Text="{Binding Status}" />

            <TextBlock Text="Generated QR:" FontWeight="Bold"/>
            <Border BorderThickness="1" Padding="8">
                <Image Source="{Binding QrImage}"
                       Width="260"
                       Height="260"
                       Stretch="Uniform"/>
            </Border>

            <TextBlock Text="Camera Preview:" FontWeight="Bold"/>
            <Border BorderThickness="1" Padding="8">
                <Image Source="{Binding Preview}"
                       Width="480"
                       Height="360"
                       Stretch="Uniform"/>
            </Border>

            <TextBlock Text="Decoded Text:" FontWeight="Bold"/>
            <TextBox Text="{Binding DecodedText}" Height="120" AcceptsReturn="True"/>

        </StackPanel>
    </ScrollViewer>

</UserControl>
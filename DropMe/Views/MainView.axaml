<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DropMe.ViewModels"
             x:Class="DropMe.Views.MainView"
             x:DataType="vm:MainViewModel">
    <UserControl.Styles>
        <Style Selector="Button.ShellIconButton">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="CornerRadius" Value="22"/>
            <Setter Property="Background" Value="#E9F4FB"/>
            <Setter Property="BorderBrush" Value="#A9C8DC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#0E476A"/>
        </Style>
    </UserControl.Styles>

    <Grid>
        <ContentControl x:Name="MainContent" />

        <Button x:Name="HistoryButton"
                Classes="ShellIconButton"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,14,14,0"
                ZIndex="20"
                ToolTip.Tip="Transfer history"
                Click="HistoryButton_Click">
            <PathIcon Width="22"
                      Height="22"
                      Data="M13,3A9,9 0 0 0 4,12H1L5,16L9,12H6A7,7 0 1 1 13,19A7,7 0 0 1 6.55,14.73L5.09,16.19A9,9 0 1 0 13,3M12,8V13L16.25,15.52L17.02,14.24L13.5,12.15V8H12Z"/>
        </Button>

        <Border IsVisible="{Binding HasPendingFileOffer}"
                Background="{DynamicResource WaterOverlayBrush}"
                ZIndex="30">
            <Border Classes="AppCard"
                    MaxWidth="360"
                    Margin="12"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel Spacing="10">
                    <TextBlock Classes="SectionTitle" Text="{Binding PendingFileOfferMessage}"/>
                    <TextBlock Text="{Binding PendingFileOfferName, StringFormat='File: {0}'}"
                               TextWrapping="Wrap"/>
                    <TextBlock Classes="BodyMuted"
                               Text="{Binding PendingFileOfferSizeText, StringFormat='Size: {0}'}"
                               TextWrapping="Wrap"/>

                    <StackPanel Orientation="Horizontal"
                                Spacing="10"
                                HorizontalAlignment="Right"
                                Margin="0,6,0,0">
                        <Button Classes="OutlinedAction"
                                Width="110"
                                Content="Reject"
                                Click="RejectIncomingFile_Click"/>
                        <Button Classes="FilledAction"
                                Width="110"
                                Content="Accept"
                                Click="AcceptIncomingFile_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>

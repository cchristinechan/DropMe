<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:DropMe.ViewModels"
    mc:Ignorable="d"
    x:Class="DropMe.Views.TransferPage"
    x:DataType="vm:MainViewModel">

  <UserControl.Styles>
    <!-- Background -->
    <Style Selector="UserControl">
      <Setter Property="Background" Value="#CFE6F5"/>
    </Style>

    <!-- Mobile-friendly typography -->
    <Style Selector="TextBlock.PageTitle">
      <Setter Property="FontSize" Value="54"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="Foreground" Value="#0E2A4A"/>
      <Setter Property="HorizontalAlignment" Value="Center"/>
      <Setter Property="TextAlignment" Value="Center"/>
    </Style>

    <Style Selector="TextBlock.PageKicker">
      <Setter Property="FontSize" Value="20"/>
      <Setter Property="FontStyle" Value="Italic"/>
      <Setter Property="Foreground" Value="#0E2A4A"/>
      <Setter Property="HorizontalAlignment" Value="Center"/>
      <Setter Property="TextAlignment" Value="Center"/>
      <Setter Property="Opacity" Value="0.85"/>
    </Style>

    <Style Selector="TextBlock.SectionTitle">
      <Setter Property="FontSize" Value="22"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="#35536D"/>
      <Setter Property="HorizontalAlignment" Value="Center"/>
      <Setter Property="TextAlignment" Value="Center"/>
    </Style>

    <Style Selector="TextBlock.BodyText">
      <Setter Property="FontSize" Value="16"/>
      <Setter Property="Foreground" Value="#1B2B3A"/>
      <Setter Property="HorizontalAlignment" Value="Center"/>
      <Setter Property="TextAlignment" Value="Center"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
      <Setter Property="Opacity" Value="0.9"/>
    </Style>

    <Style Selector="Border.Divider">
      <Setter Property="Background" Value="#7D9AB0"/>
      <Setter Property="Height" Value="2"/>
      <Setter Property="Opacity" Value="0.45"/>
      <Setter Property="CornerRadius" Value="2"/>
    </Style>

    <!-- QR card: responsive (no fixed width/height) -->
    <Style Selector="Border.QrCard">
      <Setter Property="Background" Value="#F6FBFF"/>
      <Setter Property="CornerRadius" Value="22"/>
      <Setter Property="Padding" Value="14"/>
      <Setter Property="BoxShadow" Value="0 8 22 #30000000"/>
      <Setter Property="HorizontalAlignment" Value="Center"/>
      <Setter Property="MaxWidth" Value="360"/>
    </Style>

    <!-- Revolut-style segmented slider -->
    <Style Selector="Border.SegmentHost">
      <Setter Property="Background" Value="#F5FBFE"/>
      <Setter Property="CornerRadius" Value="999"/>
      <Setter Property="Padding" Value="4"/>
      <Setter Property="HorizontalAlignment" Value="Center"/>
    </Style>

    <Style Selector="ToggleButton.Segment">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="#D0D0D0"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="CornerRadius" Value="999"/>
      <Setter Property="Padding" Value="14,10"/>
      <Setter Property="FontSize" Value="16"/>
      <Setter Property="MinWidth" Value="140"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <Style Selector="ToggleButton.Segment:checked">
      <Setter Property="Background" Value="#5A5A5A"/>
      <Setter Property="Foreground" Value="White"/>
    </Style>

    <Style Selector="ToggleButton.Segment:pointerover">
      <Setter Property="Background" Value="#2B2B2B"/>
    </Style>

    <Style Selector="ToggleButton.Segment:checked:pointerover">
      <Setter Property="Background" Value="#5A5A5A"/>
    </Style>
  </UserControl.Styles>

  <!-- Scroll so nothing is cut off on small screens -->
  <ScrollViewer VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled">
    <StackPanel Spacing="16" Margin="18,18,18,28">

      <!-- Header -->
      <TextBlock Classes="PageTitle" Text="DropMe" Margin="0,10,0,0"/>
      <!-- <TextBlock Classes="PageKicker" Text="in 2 steps"/> -->

      <Grid Margin="0,6,0,0" ColumnDefinitions="*,Auto,*" VerticalAlignment="Center">
        <Border Classes="Divider" Grid.Column="0" Margin="0,0,12,0"/>
        <TextBlock Classes="SectionTitle" Grid.Column="1" Text="How it works"/>
        <Border Classes="Divider" Grid.Column="2" Margin="12,0,0,0"/>
      </Grid>

      <TextBlock Classes="BodyText" Text="Scan or Display QR code to enter a session"/>
      <TextBlock Classes="BodyText" Text="Share the files"/>

      <Border Classes="Divider" Margin="0,6,0,0"/>
      

      <!-- Card -->
      <Border Classes="QrCard">
        <!-- Use a square container so QR never stretches off-screen -->
        <Viewbox Stretch="Uniform">
          <Grid Width="280" Height="280">
            <Image Source="{Binding QrImage}"
                   IsVisible="{Binding ShowGeneratedQr}"
                   Stretch="Uniform"/>

            <Image Source="{Binding Preview}"
                   IsVisible="{Binding IsScanning}"
                   Stretch="Uniform"/>
          </Grid>
        </Viewbox>
      </Border>
      
      <!-- Slider centered -->
      <Border Classes="SegmentHost" Margin="0,10,0,6">
        <Grid ColumnDefinitions="Auto,Auto">
          <ToggleButton Classes="Segment"
                        Grid.Column="0"
                        Content="Display"
                        IsChecked="{Binding ShowGeneratedQr}"
                        Click="DisplayMode_Click"/>

          <ToggleButton Classes="Segment"
                        Grid.Column="1"
                        Content="Scan"
                        IsChecked="{Binding IsScanning}"
                        Click="ScanMode_Click"/>
        </Grid>
      </Border>

      <!-- Status message -->
      <TextBlock Text="{Binding HomeSessionMessage}"
                 FontSize="14"
                 Foreground="#9A2A2A"
                 TextWrapping="Wrap"
                 HorizontalAlignment="Center"
                 MaxWidth="360"
                 Margin="0,6,0,0"/>
      
      <!-- ~1~ DEBUG: temp nav button @1@ -->
      <!-- <Button Content="[DEBUG] Go to Session Page" -->
      <!--         HorizontalAlignment="Center" -->
      <!--         Padding="14,10" -->
      <!--         Margin="0,10,0,0" -->
      <!--         Background="#FF6B6B" -->
      <!--         Foreground="White" -->
      <!--         CornerRadius="8" -->
      <!--         Click="DebugGoToSession_Click"/> -->
    </StackPanel>
  </ScrollViewer>
</UserControl>
<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:DropMe.ViewModels"
    mc:Ignorable="d"
    d:DesignWidth="800"
    d:DesignHeight="450"
    x:Class="DropMe.Views.TransferPage"
    x:DataType="vm:MainViewModel">
  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <StackPanel MaxWidth="430" HorizontalAlignment="Center" Spacing="16" Margin="0,2,0,0">
      <Border Classes="AppCard">
        <StackPanel Spacing="6">
          <TextBlock Classes="PageTitle" Text="Quick Connect"/>
          <TextBlock Classes="BodyMuted"
                     Text="Scan a QR code to join, or share your code to start a secure drop session."/>
        </StackPanel>
      </Border>

      <Border Classes="AppCard">
        <StackPanel Spacing="12">
          <TextBlock Classes="SectionTitle" Text="{Binding MainCardTitle}"/>
          <Border Classes="SubCard" Padding="14">
            <Grid Height="350">
              <Image Source="{Binding QrImage}"
                     IsVisible="{Binding ShowGeneratedQr}"
                     Stretch="Uniform"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"/>
              <Image Source="{Binding Preview}"
                     IsVisible="{Binding IsScanning}"
                     Stretch="Uniform"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"/>
            </Grid>
          </Border>
        </StackPanel>
      </Border>

      <Border Classes="AppCard">
        <StackPanel Spacing="12">
          <TextBlock Classes="SectionTitle" Text="Options"/>
          <StackPanel Spacing="10">
            <Button Classes="FilledAction"
                    Height="46"
                    Content="{Binding ScanButtonText}"
                    Click="ToggleScan_Click"/>
            <Button Classes="OutlinedAction"
                    Height="46"
                    Content="Generate New QR"
                    IsVisible="{Binding ShowGeneratedQr}"
                    Click="GenerateQr_Click"/>
          </StackPanel>

          <Border Classes="SubCard" IsVisible="{Binding HasHomeSessionMessage}">
            <TextBlock Text="{Binding HomeSessionMessage}" Classes="BodyMuted"/>
          </Border>
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>

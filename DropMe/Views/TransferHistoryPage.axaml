<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:DropMe.ViewModels"
             xmlns:services="using:DropMe.Services"
             mc:Ignorable="d"
             d:DesignWidth="900"
             d:DesignHeight="700"
             x:Class="DropMe.Views.TransferHistoryPage"
             x:DataType="vm:MainViewModel">
  <UserControl.Styles>
    <Style Selector="Button.HistoryLink">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="HorizontalAlignment" Value="Left"/>
      <Setter Property="HorizontalContentAlignment" Value="Left"/>
      <Setter Property="Foreground" Value="#7A8694"/>
      <Setter Property="FontSize" Value="12"/>
    </Style>

    <Style Selector="Button.HistoryLink:pointerover">
      <Setter Property="Foreground" Value="#41576A"/>
    </Style>

    <Style Selector="Button.HistoryLink:disabled">
      <Setter Property="Opacity" Value="1"/>
      <Setter Property="Foreground" Value="#8E9AA7"/>
    </Style>
  </UserControl.Styles>

  <Grid Background="#C4E0F2">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
      <StackPanel MaxWidth="860"
                  HorizontalAlignment="Center"
                  Margin="20,24,20,24"
                  Spacing="20">
        <Grid ColumnDefinitions="Auto,*"
              ColumnSpacing="16">
          <Button Grid.Column="0"
                  Height="40"
                  Padding="16,0"
                  CornerRadius="20"
                  Background="#E6E6E6"
                  Foreground="#04274A"
                  FontFamily="Georgia"
                  FontWeight="SemiBold"
                  Content="← Back"
                  Click="BackButton_Click"/>

          <StackPanel Grid.Column="1"
                      Spacing="4"
                      VerticalAlignment="Center">
            <TextBlock Text="Transfer history"
                       FontSize="30"
                       FontFamily="Georgia"
                       FontWeight="Bold"
                       Foreground="#04274A"/>
            <TextBlock Text="Completed transfers are kept locally on this device."
                       FontSize="14"
                       Foreground="#5A6F82"/>
          </StackPanel>
        </Grid>

        <Border IsVisible="{Binding HasTransferHistory}"
                Padding="18"
                CornerRadius="28"
                Background="#60FFFFFF"
                BorderBrush="#80FFFFFF"
                BorderThickness="2">
          <ItemsControl ItemsSource="{Binding TransferHistoryEntries}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="services:TransferHistoryEntry">
                <Border Margin="0,0,0,12"
                        Padding="18"
                        CornerRadius="22"
                        Background="#F7FBFE"
                        BorderBrush="#D6E5EF"
                        BorderThickness="1">
                  <Grid ColumnDefinitions="Auto,*,Auto"
                        ColumnSpacing="16">
                    <Border Width="54"
                            Height="54"
                            CornerRadius="18"
                            Background="#DCECF7"
                            VerticalAlignment="Top">
                      <PathIcon Width="28"
                                Height="28"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Foreground="#24506D"
                                Data="{Binding IconPathData}"/>
                    </Border>

                    <StackPanel Grid.Column="1"
                                Spacing="6">
                      <TextBlock Text="{Binding FileName}"
                                 FontSize="17"
                                 FontWeight="SemiBold"
                                 Foreground="#15324A"
                                 TextWrapping="Wrap"/>

                      <Button Classes="HistoryLink"
                              Content="{Binding LocationLabel}"
                              IsEnabled="{Binding CanOpenTarget}"
                              Click="OpenLocation_Click"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                Spacing="4"
                                HorizontalAlignment="Right">
                      <TextBlock Text="{Binding TimestampLabel}"
                                 FontSize="12"
                                 Foreground="#516A7F"
                                 HorizontalAlignment="Right"/>
                      <TextBlock Text="{Binding DirectionLabel}"
                                 FontSize="12"
                                 FontWeight="SemiBold"
                                 Foreground="#6A8194"
                                 HorizontalAlignment="Right"/>
                    </StackPanel>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </Border>

        <Border IsVisible="{Binding ShowEmptyTransferHistory}"
                Padding="36"
                CornerRadius="28"
                Background="#60FFFFFF"
                BorderBrush="#80FFFFFF"
                BorderThickness="2">
          <StackPanel Spacing="10"
                      HorizontalAlignment="Center">
            <TextBlock Text="No transfers yet"
                       FontSize="24"
                       FontFamily="Georgia"
                       FontWeight="Bold"
                       Foreground="#15324A"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Accepted or sent files will appear here after they complete."
                       FontSize="14"
                       Foreground="#5A6F82"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"/>
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
